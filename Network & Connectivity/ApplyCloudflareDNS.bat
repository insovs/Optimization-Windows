@echo off & title Auto Apply Cloudflare DNS.
set z=[7m& set i=[1m& set q=[0m
echo  %z% Checking privileges..%q%
net session >nul 2>&1 && (echo  %z%Admin privileges OK.%q%) || (echo  %z%Admin required.%q% & echo    %z%Right-click ^> Run as administrator.%q% & pause & exit)
cls &echo. & echo  %z%Configuring network interfaces...%q% &timeout /t 2 /nobreak >nul 2>&1 & cls
powershell -Command "$insoptic=0;$insoptis=0;$insoptidns1='1.1.1.1';$insoptidns2='1.0.0.1';Get-NetAdapter|Where-Object{$_.Status -eq 'Up'}|ForEach-Object{$insoptic++;Write-Host ('  Interface {0}: {1}' -f $insoptic,$_.Name) -ForegroundColor gray;try{Set-DnsClientServerAddress -InterfaceIndex $_.InterfaceIndex -ServerAddresses '1.1.1.1','1.0.0.1';$insopticurrent=Get-DnsClientServerAddress -InterfaceIndex $_.InterfaceIndex -AddressFamily IPv4;if($insopticurrent.ServerAddresses.Count -gt 0){$insoptidns1=$insopticurrent.ServerAddresses[0]};if($insopticurrent.ServerAddresses.Count -gt 1){$insoptidns2=$insopticurrent.ServerAddresses[1]};Write-Host '  DNS configured.' -ForegroundColor Green;$insoptis++}catch{Write-Host ('  ✗ Error: {0}' -f $_.Exception.Message) -ForegroundColor Red};Write-Host ''};Write-Host ('  Configured: {0}/{1}' -f $insoptis,$insoptic) -ForegroundColor Green;Write-Host '';Write-Host '  Clearing DNS cache..' -ForegroundColor Yellow;try{Clear-DnsClientCache;Write-Host '  Cache cleared.' -ForegroundColor Green}catch{Write-Host ' Cache error.' -ForegroundColor Red};Write-Host '';Write-Host '  CONFIGURATION:' -ForegroundColor darkcyan;Write-Host ('  Primary DNS   : {0}' -f $insoptidns1) -ForegroundColor White;Write-Host ('  Secondary DNS : {0}' -f $insoptidns2) -ForegroundColor White;Write-Host '';Write-Host '  Benefits:' -ForegroundColor White;Write-Host '  • Faster browsing' -ForegroundColor White;Write-Host '  • Anti-malware protection' -ForegroundColor White;Write-Host '  • Privacy respected' -ForegroundColor White"
echo. & echo  Press any key to close... & pause >nul 2>&1